# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Sync protegido (POST /api/wow/playable-race/sync e .../playable-classes/sync)
