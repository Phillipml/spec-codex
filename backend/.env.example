BNET_CLIENT_ID=
BNET_CLIENT_SECRET=
BNET_TOKEN_URL=https://oauth.battle.net/token
BNET_API_BASE=https://us.api.blizzard.com

# Produção: PostgreSQL (omitir em dev para usar SQLite)
# DATABASE_URL=postgres://user:pass@host:5432/dbname
